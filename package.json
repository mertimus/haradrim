{
  "name": "haradrim",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "backend:dev": "sh -c 'if [ -f .env.local ]; then node --watch --env-file=.env.local backend/server.mjs; else node --watch backend/server.mjs; fi'",
    "backend:start": "sh -c 'if [ -f .env.local ]; then node --env-file=.env.local backend/server.mjs; else node backend/server.mjs; fi'",
    "dev": "sh -c 'npm run backend:dev & backend_pid=$!; trap \"kill $backend_pid\" EXIT INT TERM; vite'",
    "dev:frontend": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@bonfida/spl-name-service": "^3.0.19",
    "@dagrejs/dagre": "^2.0.4",
    "@solana/web3.js": "^1.98.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/d3-force": "^3.0.10",
    "@xyflow/react": "^12.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "lucide-react": "^0.576.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "jsdom": "^28.1.0",
    "shadcn": "^3.8.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  }
}
