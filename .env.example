# Backend
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=replace-with-backend-helius-key
HELIUS_API_KEY=
BIRDEYE_API_KEY=
DIALECT_API_KEY=
COINGECKO_API_KEY=
SESSION_SECRET=replace-with-a-long-random-secret
SESSION_COOKIE_NAME=haradrim_sid
BACKEND_DEV_ORIGIN=http://localhost:8080

# Optional backend tuning
SESSION_WINDOW_MS=600000
SESSION_BUDGET_UNITS=40
IP_WINDOW_MS=600000
IP_BUDGET_UNITS=120
CACHE_MAX_ENTRIES=1000
CACHE_MAX_BODY_BYTES=2000000
REQUEST_BODY_LIMIT_BYTES=32000
JSON_PROXY_BODY_LIMIT_BYTES=64000
FETCH_TIMEOUT_MS=15000
PROXY_TTL_MS=300000
WALLET_ANALYSIS_TTL_MS=300000
TRACE_ANALYSIS_TTL_MS=300000
MAX_SLICE_CONCURRENCY=16
MAX_ACCOUNT_TYPE_CONCURRENCY=8
MAX_WALLET_ANALYSIS_CONCURRENCY=2
MAX_TRACE_ANALYSIS_CONCURRENCY=1
MAX_GTFA_RPC_CONCURRENCY=2

# Optional frontend public config
# Lightweight browser reads only. GTFA-heavy flows still use the backend proxy.
VITE_PUBLIC_HELIUS_RPC_URL=https://your-fast-mainnet.helius-rpc.com
VITE_PUBLIC_ORIGIN=http://localhost:5173
